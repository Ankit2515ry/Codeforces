#include <bits/stdc++.h>
using namespace std;
void solve() {
    int n;
    cin>>n;
    vector<int>a(n);
    for(auto &it:a)cin>>it;
    unordered_set<int>st;
    for(auto it:a){
        if(st.find(it)!=st.end()){
            cout<<"YES"<<endl;
            return;
        }
        st.insert(it);
    }
    cout<<"NO"<<endl;
}
int main() {
    int t;
    cin >> t;
    while (t--) solve();
}